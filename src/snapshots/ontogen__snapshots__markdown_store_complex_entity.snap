impl Store {
    pub async fn list_articles(&self, limit: Option<u64>, offset: Option<u64>) -> Result<Vec<Article>, AppError> {
        let mut articles = Vec::new();
        for (id, doc) in self.vault().read_all(ARTICLES_DIR).map_err(AppError::from)? {
            let fm: ArticleFrontmatter = doc.deserialize().map_err(AppError::from)?;
            articles.push(fm.into_article(id, doc.body().to_string()));
        }
        let offset = offset.unwrap_or(0) as usize;
        let limit = limit.map(|l| l as usize).unwrap_or(usize::MAX);
        let mut articles: Vec<Article> = articles.into_iter().skip(offset).take(limit).collect();
        for entity in &mut articles {
            self.populate_article_relations(entity).await?;
        }
        Ok(articles)
    }

    pub async fn get_article(&self, id: &str) -> Result<Article, AppError> {
        let doc = self
            .vault()
            .read_record_opt(ARTICLES_DIR, id)
            .map_err(AppError::from)?
            .ok_or_else(|| AppError::ArticleNotFound(id.to_string()))?;
        let fm: ArticleFrontmatter = doc.deserialize().map_err(AppError::from)?;
        let mut article = fm.into_article(id.to_string(), doc.body().to_string());
        self.populate_article_relations(&mut article).await?;
        Ok(article)
    }

    pub async fn create_article(&self, mut article: Article) -> Result<Article, AppError> {
        hooks::before_create(self, &mut article).await?;

        let mut doc = markdown_store::Document::new();
        doc.merge_serialize(&ArticleFrontmatter::from_article(&article), ARTICLE_FM_FIELDS).map_err(AppError::from)?;
        doc.set_body(article.body.clone());
        let id = self
            .vault()
            .create_record_derived(ARTICLES_DIR, Some(article.id.as_str()).filter(|s| !s.is_empty()), None, &doc)
            .map_err(AppError::from)?;

        let created = self.get_article(&id).await?;
        self.emit_change(ChangeOp::Created, EntityKind::Article, id);
        hooks::after_create(self, &created).await?;
        Ok(created)
    }

    pub async fn update_article(&self, id: &str, updates: ArticleUpdate) -> Result<Article, AppError> {
        let current = self.get_article(id).await?;
        hooks::before_update(self, &current, &updates).await?;

        self.vault()
            .modify_record(ARTICLES_DIR, id, |doc| {
                let fm: ArticleFrontmatter = doc.deserialize()?;
                let mut article = fm.into_article(id.to_string(), doc.body().to_string());
                updates.apply(&mut article);
                doc.merge_serialize(&ArticleFrontmatter::from_article(&article), ARTICLE_FM_FIELDS)?;
                doc.set_body(article.body);
                Ok(())
            })
            .map_err(AppError::from)?;

        let result = self.get_article(id).await?;
        self.emit_change(ChangeOp::Updated, EntityKind::Article, id.to_string());
        hooks::after_update(self, &result).await?;
        Ok(result)
    }

    pub async fn delete_article(&self, id: &str) -> Result<(), AppError> {
        hooks::before_delete(self, id).await?;

        match self.vault().remove_record(ARTICLES_DIR, id) {
            Ok(()) => {}
            Err(markdown_store::Error::NotFound { .. }) => {
                return Err(AppError::ArticleNotFound(id.to_string()));
            }
            Err(e) => return Err(AppError::from(e)),
        }

        self.emit_change(ChangeOp::Deleted, EntityKind::Article, id.to_string());
        hooks::after_delete(self, id).await?;
        Ok(())
    }

    pub(crate) async fn populate_article_relations(
        &self,
        article: &mut crate::schema::Article,
