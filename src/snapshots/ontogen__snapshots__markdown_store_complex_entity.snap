}

impl From<crate::schema::UpdateArticleInput> for ArticleUpdate {
    fn from(input: crate::schema::UpdateArticleInput) -> Self {
        Self { title: input.title, tags: input.tags.map(markdown_store::wikilink::strip_vec), body: input.body }
    }
}

impl From<crate::schema::CreateArticleInput> for Article {
    fn from(input: crate::schema::CreateArticleInput) -> Self {
