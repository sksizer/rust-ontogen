impl Store {
    pub async fn list_articles(&self) -> Result<Vec<Article>, AppError> {
        let models = article::Entity::find().all(self.db()).await.map_err(|e| AppError::DbError(e.to_string()))?;

        let mut entities: Vec<Article> = models.iter().map(Article::from_model).collect();
        for entity in &mut entities {
            self.populate_article_relations(entity).await?;
