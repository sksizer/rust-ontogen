    pub async fn update_article(&self, id: &str, updates: ArticleUpdate) -> Result<Article, AppError> {
        let existing_model = article::Entity::find_by_id(id)
            .one(self.db())
            .await
            .map_err(|e| AppError::DbError(e.to_string()))?
            .ok_or_else(|| AppError::ArticleNotFound(id.to_string()))?;

        let mut current = Article::from_model(&existing_model);
        self.populate_article_relations(&mut current).await?;

        hooks::before_update(self, &current, &updates).await?;

        let tags_changed = updates.tags.is_some();

        updates.apply(&mut current);

        let active = current.to_active_model();
        active.update(self.db()).await.map_err(|e| AppError::DbError(e.to_string()))?;

        if tags_changed {
            self.sync_junction("article_tags", "article_id", "tag_id", id, &current.tags).await?;
        }

        let result = self.get_article(id).await?;
        self.emit_change(ChangeOp::Updated, EntityKind::Article, id.to_string());

        hooks::after_update(self, &result).await?;
        Ok(result)
