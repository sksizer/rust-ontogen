    pub async fn get_article(&self, id: &str) -> Result<Article, AppError> {
        let model = article::Entity::find_by_id(id)
            .one(self.db())
            .await
            .map_err(|e| AppError::DbError(e.to_string()))?
            .ok_or_else(|| AppError::ArticleNotFound(id.to_string()))?;

        let mut entity = Article::from_model(&model);
        self.populate_article_relations(&mut entity).await?;
        Ok(entity)
