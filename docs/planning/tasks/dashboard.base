views:
  - type: table
    name: Table
    filters:
      and:
        - file.path.startsWith("planning/tasks")
        - file.ext == "md"
        - file.name != "README"
    order:
      - file.name
      - status
      - resolution
    sort:
      - property: status
        direction: DESC
    columnSize:
      file.name: 421
      note.status: 369
