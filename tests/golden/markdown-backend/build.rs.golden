// ═══════════════════════════════════════════════════════════════════════
// GOLDEN SPEC — target consumer build.rs for a markdown-backed ontogen app.
//
// This file is the contract for the backend-cutover PR (config/builder
// surface) and is NOT compiled yet. Edit it to steer the implementation:
// the conformance harness grades the real generators against this tree.
// ═══════════════════════════════════════════════════════════════════════

use ontogen::{Backend, IdStrategy, MarkdownIoOptions, MarkdownLayout, Pipeline};

fn main() {
    println!("cargo:rerun-if-changed=build.rs");
    ontogen::emit_rerun_directives_excluding(&std::path::PathBuf::from("src/api/v1"), &["generated"]);

    // ── Pipeline form (recommended) ─────────────────────────────────────
    //
    // Exactly one persistence stage ⇒ the store backend is inferred; with
    // both `.seaorm(...)` and `.markdown_io(...)` configured, an explicit
    // `.store_backend(...)` call is required and its absence is an error.
    Pipeline::new("src/schema")
        .markdown_io(
            "src/persistence/markdown/generated",
            MarkdownIoOptions {
                // Where the .md records live, relative to the consumer crate root.
                vault_root: "data/vault".into(),
                // data/vault/<entity-dir>/<id>.md
                layout: MarkdownLayout::PerEntityDir,
                // New records without a caller-supplied id slugify this field.
                id_strategy: IdStrategy::SlugFromField("title".into()),
                // Loud error past this many records per list() (ADR scale ceiling).
                list_cap: 10_000,
            },
        )
        .dtos("src/schema/dto")
        .store("src/store/generated", Some("src/store/hooks"))
        .api("src/api/v1/generated", "AppState")
        .build()
        .unwrap_or_else(|e| {
            e.emit_cargo_warning();
            panic!("ontogen pipeline failed: {e}");
        });
}

