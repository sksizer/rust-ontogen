// ═══════════════════════════════════════════════════════════════════════
// GOLDEN SPEC — generated markdown store module for the minimal entity
//
//     #[ontology(directory = "notes")]
//     pub struct Note {
//         #[ontology(id)]   pub id: String,
//         pub title: String,
//         #[ontology(body)] pub body: String,
//     }
//
// One deliberately small, human-verifiable shape contract. The emitter PR
// is graded against this file (rustfmt-normalized diff); the full entity
// set (relations, m2m, has_many) is expanded generate-then-review in the
// conformance PR so spec authority stays with a reviewable artifact.
//
// Contract pinned here, beyond the literal text:
//   • method signatures, hook call sites, and emit_change points are
//     byte-identical to the SeaORM emission — the downstream byte-identical
//     invariant depends on it;
//   • the only consumer-contract differences vs SeaORM: self.vault()
//     instead of self.db(), AppError::Md instead of AppError::DbError;
//   • frontmatter access goes through the generated {Entity}Frontmatter
//     newtype (lives in the markdown-io generated module) — wikilink
//     encode/strip happens there, never inline in CRUD bodies;
//   • create routes through create_record_derived (id derivation + slug
//     dedup + write under one lock hold);
//   • update is a read-modify-write via modify_record; a no-op update is a
//     zero-diff write (Document is change-aware).
// ═══════════════════════════════════════════════════════════════════════

//! Generated by ontogen (markdown backend) — do not edit.

use crate::persistence::markdown::generated::note::{NoteFrontmatter, NOTE_FM_FIELDS};
use crate::schema::{AppError, ChangeOp, EntityKind, Note};
use crate::store::hooks::note as hooks;
use crate::store::Store;

const NOTES_DIR: &str = "notes";

/// Patch struct for partial updates. Field semantics match the SeaORM
/// emission exactly (Option = "provided?"; Option<Option<T>> for nullable
/// fields).
pub struct NoteUpdate {
    pub title: Option<String>,
    pub body: Option<String>,
}

impl NoteUpdate {
    pub fn apply(&self, note: &mut Note) {
        if let Some(v) = &self.title {
            note.title = v.clone();
        }
        if let Some(v) = &self.body {
            note.body = v.clone();
        }
    }
}

impl From<crate::schema::UpdateNoteInput> for NoteUpdate {
    fn from(input: crate::schema::UpdateNoteInput) -> Self {
        Self { title: input.title, body: input.body }
    }
}

impl From<crate::schema::CreateNoteInput> for Note {
    fn from(input: crate::schema::CreateNoteInput) -> Self {
        Self { id: input.id.unwrap_or_default(), title: input.title, body: input.body }
    }
}

impl Store {
    pub async fn list_notes(&self, limit: Option<u64>, offset: Option<u64>) -> Result<Vec<Note>, AppError> {
        let mut notes = Vec::new();
        for (id, doc) in self.vault().read_all(NOTES_DIR).map_err(AppError::from)? {
            let fm: NoteFrontmatter = doc.deserialize().map_err(AppError::from)?;
            notes.push(fm.into_note(id, doc.body().to_string()));
        }
        let offset = offset.unwrap_or(0) as usize;
        let limit = limit.map(|l| l as usize).unwrap_or(usize::MAX);
        Ok(notes.into_iter().skip(offset).take(limit).collect())
    }

    pub async fn get_note(&self, id: &str) -> Result<Note, AppError> {
        let doc = self
            .vault()
            .read_record_opt(NOTES_DIR, id)
            .map_err(AppError::from)?
            .ok_or_else(|| AppError::NoteNotFound(id.to_string()))?;
        let fm: NoteFrontmatter = doc.deserialize().map_err(AppError::from)?;
        Ok(fm.into_note(id.to_string(), doc.body().to_string()))
    }

    pub async fn create_note(&self, mut note: Note) -> Result<Note, AppError> {
        hooks::before_create(self, &mut note).await?;
        let mut doc = markdown_store::Document::new();
        doc.merge_serialize(&NoteFrontmatter::from_note(&note), NOTE_FM_FIELDS).map_err(AppError::from)?;
        doc.set_body(note.body.clone());
        let id = self
            .vault()
            .create_record_derived(
                NOTES_DIR,
                Some(note.id.as_str()).filter(|s| !s.is_empty()),
                Some(note.title.as_str()),
                &doc,
            )
            .map_err(AppError::from)?;
        let created = self.get_note(&id).await?;
        self.emit_change(ChangeOp::Created, EntityKind::Note, id);
        hooks::after_create(self, &created).await?;
        Ok(created)
    }

    pub async fn update_note(&self, id: &str, updates: NoteUpdate) -> Result<Note, AppError> {
        let current = self.get_note(id).await?;
        hooks::before_update(self, &current, &updates).await?;
        self.vault()
            .modify_record(NOTES_DIR, id, |doc| {
                let fm: NoteFrontmatter = doc.deserialize()?;
                let mut note = fm.into_note(id.to_string(), doc.body().to_string());
                updates.apply(&mut note);
                doc.merge_serialize(&NoteFrontmatter::from_note(&note), NOTE_FM_FIELDS)?;
                doc.set_body(note.body);
                Ok(())
            })
            .map_err(AppError::from)?;
        let result = self.get_note(id).await?;
        self.emit_change(ChangeOp::Updated, EntityKind::Note, id.to_string());
        hooks::after_update(self, &result).await?;
        Ok(result)
    }

    pub async fn delete_note(&self, id: &str) -> Result<(), AppError> {
        hooks::before_delete(self, id).await?;
        match self.vault().remove_record(NOTES_DIR, id) {
            Ok(()) => {}
            Err(markdown_store::Error::NotFound { .. }) => {
                return Err(AppError::NoteNotFound(id.to_string()));
            }
            Err(e) => return Err(AppError::from(e)),
        }
        self.emit_change(ChangeOp::Deleted, EntityKind::Note, id.to_string());
        hooks::after_delete(self, id).await?;
        Ok(())
    }
}
